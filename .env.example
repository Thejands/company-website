# Site environment: production (live) | staging (preview, blocks indexing + live emails)
PUBLIC_SITE_ENV=production

# Microsoft Bing - IndexNow (Bing Webmaster Tools → IndexNow → Get key)
# Key file is auto-served at https://thejands.in/{key}.txt via public/ directory
PUBLIC_INDEXNOW_KEY=your-32-char-indexnow-key-here
# PUBLIC_BING_VERIFY=  (only needed if not yet verified in Bing Webmaster Tools)

# Google Tag Manager (loads only when PUBLIC_SITE_ENV=production)
PUBLIC_GTM_ID=GTM-XXXXXXXXX

# reCAPTCHA Enterprise - invisible, score-based (https://console.cloud.google.com/security/recaptcha)
# PUBLIC_RECAPTCHA_SITE_KEY  - Site key from reCAPTCHA Enterprise console (public, safe to expose)
# RECAPTCHA_ENTERPRISE_API_KEY - Google Cloud API key restricted to "reCAPTCHA Enterprise API"
#                                Create at: Cloud Console → APIs & Services → Credentials → Create API Key
#                                Restrict to: API restrictions → reCAPTCHA Enterprise API
# RECAPTCHA_PROJECT_ID        - GCP project ID (matches site key project)
PUBLIC_RECAPTCHA_SITE_KEY=6Lxx-mock-recaptcha-site-key-here-xx
RECAPTCHA_ENTERPRISE_API_KEY=AIzaSy-mock-google-cloud-api-key-here
RECAPTCHA_PROJECT_ID=your-gcp-project-id

# Resend (contact + careers emails) - https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Your Company <noreply@yourdomain.com>
CONTACT_NOTIFY_EMAIL=hello@yourdomain.com

# Google Sheets - service account JSON (raw or base64) + spreadsheet shared with SA email
GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "your-gcp-project-id", "private_key_id": "your-key-id", "private_key": "-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n", "client_email": "your-sa@your-gcp-project-id.iam.gserviceaccount.com", "client_id": "000000000000000000000", "auth_uri": "https://accounts.google.com/o/oauth2/auth", "token_uri": "https://oauth2.googleapis.com/token", "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs", "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-gcp-project-id.iam.gserviceaccount.com", "universe_domain": "googleapis.com"}'
GOOGLE_SHEETS_SPREADSHEET_ID=your-google-sheets-spreadsheet-id
GOOGLE_SHEETS_TAB_NAME=contact_submissions
GOOGLE_SHEETS_ERRORS_TAB_NAME=errors

# Optional: Upstash Redis rate limit (5 submissions / hour per IP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin (submissions viewer + ATS admin)
ADMIN_PASSWORD=your-strong-admin-password-here

# Supabase (ATS / careers) - https://supabase.com/dashboard
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Twitter/X @handle for twitter:creator meta (optional if PUBLIC_SOCIAL_X is set)
PUBLIC_TWITTER_HANDLE=YourHandle

# Social profiles (footer icons + JSON-LD sameAs). Leave blank to hide.
PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/yourhandle
PUBLIC_SOCIAL_FACEBOOK=
PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/company/yourcompany
PUBLIC_SOCIAL_DISCORD=
PUBLIC_SOCIAL_X=https://x.com/YourHandle
PUBLIC_SOCIAL_GITHUB=https://github.com/YourOrg
