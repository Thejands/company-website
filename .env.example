# Site environment: production (live) | staging (preview, blocks indexing + analytics)
# Vercel preview deploys auto-detect as staging when this is unset.
PUBLIC_SITE_ENV=production

# Google Tag Manager (loads only when PUBLIC_SITE_ENV=production)
PUBLIC_GTM_ID=GTM-XXXXXXX

# reCAPTCHA v2 checkbox - contact page only (https://www.google.com/recaptcha/admin)
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Optional: forward contact submissions (Formspree, Getform, etc.)
PUBLIC_CONTACT_FORM_URL=

# Twitter/X @handle for twitter:creator meta (optional if PUBLIC_SOCIAL_X is set)
PUBLIC_TWITTER_HANDLE=

# Social profiles (footer icons + JSON-LD sameAs). Leave blank to hide.
PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/thejands
PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/thejands
PUBLIC_SOCIAL_LINKEDIN=https://linkedin.com/company/thejands
PUBLIC_SOCIAL_DISCORD=https://discord.gg/thejands
PUBLIC_SOCIAL_X=https://x.com/thejands
PUBLIC_SOCIAL_GITHUB=https://github.com/thejands
