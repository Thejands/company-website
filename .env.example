# Site environment: production (live) | staging (preview, blocks indexing + live emails)
PUBLIC_SITE_ENV=production

# Google Tag Manager (loads only when PUBLIC_SITE_ENV=production)
PUBLIC_GTM_ID=GTM-XXXXXXX

# reCAPTCHA v2 checkbox - contact page only (https://www.google.com/recaptcha/admin)
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Resend (contact + careers emails) - https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Thejands <hello@thejands.in>
CONTACT_NOTIFY_EMAIL=hello@thejands.in

# Google Sheets - service account JSON (raw or base64) + spreadsheet shared with SA email
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=contact_submissions
GOOGLE_SHEETS_ERRORS_TAB_NAME=errors

# Optional: Upstash Redis rate limit (5 submissions / hour per IP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin (submissions viewer + ATS admin)
ADMIN_PASSWORD=

# Supabase (ATS / careers) - project: Thejands_website
# Dashboard: https://supabase.com/dashboard/project/bvyuyhmgzswzzkohwxzq
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Twitter/X @handle for twitter:creator meta (optional if PUBLIC_SOCIAL_X is set)
PUBLIC_TWITTER_HANDLE=Thejands_ofc

# Social profiles (footer icons + JSON-LD sameAs). Leave blank to hide.
PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/thejandsofficial
PUBLIC_SOCIAL_FACEBOOK=
PUBLIC_SOCIAL_LINKEDIN=https://www.linkedin.com/in/thejands
PUBLIC_SOCIAL_DISCORD=
PUBLIC_SOCIAL_X=https://x.com/Thejands_ofc
PUBLIC_SOCIAL_GITHUB=https://github.com/Thejands
