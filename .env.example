# Site environment: production (live) | staging (preview, blocks indexing + live emails)
PUBLIC_SITE_ENV=production

# Google Tag Manager (loads only when PUBLIC_SITE_ENV=production)
PUBLIC_GTM_ID=GTM-NNP3L8JS

# reCAPTCHA Enterprise — invisible, score-based (https://console.cloud.google.com/security/recaptcha)
# PUBLIC_RECAPTCHA_SITE_KEY  — Site key from reCAPTCHA Enterprise console (public, safe to expose)
# RECAPTCHA_ENTERPRISE_API_KEY — Google Cloud API key restricted to "reCAPTCHA Enterprise API"
#                                Create at: Cloud Console → APIs & Services → Credentials → Create API Key
#                                Restrict to: API restrictions → reCAPTCHA Enterprise API
# RECAPTCHA_PROJECT_ID        — GCP project ID (matches site key project)
PUBLIC_RECAPTCHA_SITE_KEY=6LdsQ_gsAAAAAK2QTurGy_szSM8xxfuFhE8xLPo6
RECAPTCHA_ENTERPRISE_API_KEY=AIzaSyCunU9GrRsgqn0v0II_WHOARzEUPOfLp_4
RECAPTCHA_PROJECT_ID=thejands-website

# Resend (contact + careers emails) - https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Thejands <hello@thejands.in>
CONTACT_NOTIFY_EMAIL=hello@thejands.in

# Google Sheets - service account JSON (raw or base64) + spreadsheet shared with SA email
GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "thejands-website", "private_key_id": "YOUR_NEW_KEY_ID", "private_key": "-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANBg...[TRUNCATED]...\n-----END PRIVATE KEY-----\n", "client_email": "website@thejands-website.iam.gserviceaccount.com", "client_id": "111547591502626263359", "auth_uri": "https://accounts.google.com/o/oauth2/auth", "token_uri": "https://oauth2.googleapis.com/token", "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs", "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/website%40thejands-website.iam.gserviceaccount.com", "universe_domain": "googleapis.com"}'
GOOGLE_SHEETS_SPREADSHEET_ID=1TiGb7u3S54EsNwpPnMCfQ4EJQToHQolK2uKoHE7ZkS0
