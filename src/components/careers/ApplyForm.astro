---
interface Props {
  jobSlug: string;
  jobTitle: string;
}

const { jobSlug, jobTitle } = Astro.props;
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
---

<form
  id="apply-form"
  class="space-y-5"
  enctype="multipart/form-data"
  data-recaptcha-key={recaptchaSiteKey ?? ""}
>
  <input type="hidden" name="jobSlug" value={jobSlug} />
  <p class="text-body-sm text-body">
    Applying for <strong class="text-ink">{jobTitle}</strong>
  </p>
  <div
    id="apply-status"
    class="hidden rounded-lg border p-4 text-body-sm"
    role="status"
  >
  </div>

  <div>
    <label for="fullName" class="mb-1.5 block text-body-sm font-medium text-ink"
      >Full name</label
    >
    <input
      id="fullName"
      name="fullName"
      type="text"
      required
      autocomplete="name"
      class="h-11 w-full rounded-full border border-hairline bg-canvas/90 px-4 text-body-md"
    />
  </div>
  <div>
    <label
      for="apply-email"
      class="mb-1.5 block text-body-sm font-medium text-ink">Email</label
    >
    <input
      id="apply-email"
      name="email"
      type="email"
      required
      autocomplete="email"
      class="h-11 w-full rounded-full border border-hairline bg-canvas/90 px-4 text-body-md"
    />
  </div>
  <div>
    <label for="phone" class="mb-1.5 block text-body-sm font-medium text-ink"
      >Phone (optional)</label
    >
    <input
      id="phone"
      name="phone"
      type="tel"
      autocomplete="tel"
      class="h-11 w-full rounded-full border border-hairline bg-canvas/90 px-4 text-body-md"
    />
  </div>
  <div>
    <label
      for="linkedinUrl"
      class="mb-1.5 block text-body-sm font-medium text-ink"
      >LinkedIn (optional)</label
    >
    <input
      id="linkedinUrl"
      name="linkedinUrl"
      type="url"
      class="h-11 w-full rounded-full border border-hairline bg-canvas/90 px-4 text-body-md"
      placeholder="https://linkedin.com/in/..."
    />
  </div>
  <div>
    <label for="resume" class="mb-1.5 block text-body-sm font-medium text-ink"
      >Resume (PDF or Word, max 5 MB)</label
    >
    <input
      id="resume"
      name="resume"
      type="file"
      accept=".pdf,.doc,.docx,application/pdf"
      class="w-full text-body-sm"
    />
  </div>
  <div>
    <label
      for="coverLetter"
      class="mb-1.5 block text-body-sm font-medium text-ink"
      >Cover letter (optional)</label
    >
    <textarea
      id="coverLetter"
      name="coverLetter"
      rows="5"
      class="w-full resize-y rounded-xl border border-hairline bg-canvas/90 px-4 py-3 text-body-md"
    ></textarea>
  </div>
  <button
    type="submit"
    id="apply-submit"
    class="inline-flex h-10 items-center justify-center rounded-full bg-ink px-6 text-body-sm font-medium text-on-primary transition-opacity disabled:opacity-60"
  >
    Submit application
  </button>

  {
    recaptchaSiteKey ? (
      <p class="text-caption-sm text-mute">
        Protected by reCAPTCHA Enterprise.{" "}
        <a
          href="https://policies.google.com/privacy"
          class="underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Privacy
        </a>{" "}
        &{" "}
        <a
          href="https://policies.google.com/terms"
          class="underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Terms
        </a>
        .
      </p>
    ) : null
  }
</form>

{
  /* Enterprise invisible reCAPTCHA — no visible widget, token generated on submit */
  recaptchaSiteKey && (
    <script
      src={`https://www.google.com/recaptcha/enterprise.js?render=${recaptchaSiteKey}`}
      async
      defer
    />
  )
}

<script>
  const RECAPTCHA_ACTION = "CAREER_APPLY";

  const form = document.getElementById("apply-form") as HTMLFormElement;
  const statusEl = document.getElementById("apply-status");
  const submitBtn = document.getElementById(
    "apply-submit",
  ) as HTMLButtonElement;

  function showStatus(message: string, isError: boolean) {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.className = isError
      ? "rounded-lg border border-red-300 bg-red-50 p-4 text-body-sm text-ink"
      : "rounded-lg border border-hairline bg-surface-soft p-4 text-body-sm text-body";
    statusEl.classList.remove("hidden");
  }

  /**
   * Get a reCAPTCHA Enterprise token invisibly.
   * Returns null if grecaptcha is not available (not configured or not loaded yet).
   */
  function getEnterpriseToken(siteKey: string): Promise<string | null> {
    return new Promise((resolve) => {
      const g = (
        window as unknown as {
          grecaptcha?: {
            enterprise?: {
              ready: (cb: () => void) => void;
              execute: (
                siteKey: string,
                options: { action: string },
              ) => Promise<string>;
            };
          };
        }
      ).grecaptcha;

      if (!g?.enterprise) {
        // reCAPTCHA not configured — submit without token
        resolve(null);
        return;
      }

      g.enterprise.ready(async () => {
        try {
          const token = await g.enterprise!.execute(siteKey, {
            action: RECAPTCHA_ACTION,
          });
          resolve(token);
        } catch (err) {
          console.error("[recaptcha] execute() failed:", err);
          resolve(null);
        }
      });
    });
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const siteKey = form.dataset.recaptchaKey;

    submitBtn.disabled = true;
    submitBtn.textContent = "Submitting…";

    try {
      // Build FormData from the form
      const formData = new FormData(form);

      // Get Enterprise token if reCAPTCHA is configured
      if (siteKey) {
        const token = await getEnterpriseToken(siteKey);
        if (!token) {
          showStatus(
            "Security check failed. Please refresh the page and try again.",
            true,
          );
          return;
        }
        formData.append("recaptchaToken", token);
      }

      const res = await fetch("/api/careers/apply", {
        method: "POST",
        body: formData,
      });

      const data = (await res.json()) as {
        ok?: boolean;
        message?: string;
        error?: string;
      };

      if (res.ok && data.ok) {
        showStatus(
          data.message ?? "Application submitted. We'll be in touch soon.",
          false,
        );
        form.reset();
        return;
      }

      showStatus(data.error ?? "Submission failed. Please try again.", true);
    } catch {
      showStatus("Network error. Please try again.", true);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Submit application";
    }
  });
</script>
