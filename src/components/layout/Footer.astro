---
import Logo from "@/components/ui/Logo.astro";
import AnimatedSocialLinks from "@/components/ui/AnimatedSocialLinks";
import { siteConfig } from "@/config/site";

const year = new Date().getFullYear();

const primaryLinks = siteConfig.footerLinks.filter((l) =>
  ["/services", "/process", "/about", "/careers", "/contact"].includes(l.href),
);
const legalLinks = siteConfig.footerLinks.filter((l) =>
  ["/privacy", "/terms", "/cookies"].includes(l.href),
);
---

<footer class="border-t border-hairline bg-canvas">
  <div class="container-page pt-12 pb-10">
    <div class="grid gap-12 md:grid-cols-[1fr_auto]">
      <!-- Brand column -->
      <div class="max-w-xs">
        <Logo height={32} showWordmark={false} />
        <p class="mt-4 text-body-sm text-body leading-relaxed">
          Enterprise software, AI solutions, and technology consulting —
          delivered by founders who own every outcome.
        </p>
        <p class="mt-4 text-body-sm">
          <a
            href={`mailto:${siteConfig.contact.email}`}
            class="font-medium text-ink underline underline-offset-2 hover:opacity-70 transition-opacity"
          >
            {siteConfig.contact.email}
          </a>
        </p>
        <AnimatedSocialLinks
          links={[...siteConfig.socialLinks]}
          className="mt-5"
          client:visible
        />
      </div>

      <!-- Navigation columns -->
      <div class="flex gap-12 sm:gap-16">
        <nav aria-label="Footer navigation">
          <p
            class="mb-3 text-caption-sm font-semibold uppercase tracking-widest text-mute"
          >
            Company
          </p>
          <ul class="space-y-2.5 text-body-sm">
            {
              primaryLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-body transition-colors hover:text-ink"
                  >
                    {link.text}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <nav aria-label="Legal navigation">
          <p
            class="mb-3 text-caption-sm font-semibold uppercase tracking-widest text-mute"
          >
            Legal
          </p>
          <ul class="space-y-2.5 text-body-sm">
            {
              legalLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-body transition-colors hover:text-ink"
                  >
                    {link.text}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-hairline pt-6 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-caption-sm text-mute">
        © {year} Thejands. All rights reserved.
      </p>
      <p class="text-caption-sm text-mute">
        Built by founders. Shipped with care.
      </p>
    </div>
  </div>
</footer>
