---
import Logo from "@/components/ui/Logo.astro";
import PlugIcon from "@/components/ui/PlugIcon.astro";
import SocialLinks from "@/components/ui/SocialLinks.astro";
import { siteConfig } from "@/config/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-hairline bg-canvas/80 backdrop-blur-sm">
  <div class="container-page section-spacing pb-10 pt-12">
    <div class="grid gap-10 md:grid-cols-[1.2fr_1fr]">
      <div>
        <div class="flex items-center gap-2.5">
          <PlugIcon size={22} class="text-ink" />
          <Logo height={28} showWordmark={false} />
        </div>
        <p class="mt-3 max-w-sm text-body-sm text-body">
          {siteConfig.tagline}. Web, mobile, and custom software - built by
          founders who stay in the room.
        </p>
        <p class="mt-4 text-body-sm">
          <a
            href={`mailto:${siteConfig.contact.email}`}
            class="text-ink underline underline-offset-2"
          >
            {siteConfig.contact.email}
          </a>
        </p>
        <SocialLinks links={siteConfig.socialLinks} class="mt-5" />
      </div>
      <nav aria-label="Footer">
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-body-sm text-body">
          {
            siteConfig.footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="hover:text-ink underline-offset-2 hover:underline"
                >
                  {link.text}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
    <p class="mt-10 border-t border-hairline pt-6 text-caption-sm text-mute">
      © {year} Thejands. All rights reserved.
    </p>
  </div>
</footer>
