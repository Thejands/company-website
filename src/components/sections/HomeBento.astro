---
import { servicesPage, stats, processPage } from "@/config/content";
import { siteConfig } from "@/config/site";

const offerings = servicesPage.offerings;

// Inline SVG paths — no React hydration dependency, always visible
const icons: Record<string, { paths: string[]; viewBox?: string }> = {
  globe: {
    paths: [
      "M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z",
      "M2 12h20",
      "M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z",
    ],
  },
  layers: {
    paths: ["M12 2 2 7l10 5 10-5-10-5z", "M2 17l10 5 10-5", "M2 12l10 5 10-5"],
  },
  terminal: {
    paths: ["M4 17l6-6-6-6", "M12 19h8"],
  },
};
---

<section class="section-spacing" aria-labelledby="bento-heading">
  <div class="container-page">
    <h2
      id="bento-heading"
      class="fade-in is-visible font-display text-display-lg text-ink"
    >
      What we build
    </h2>
    <p class="fade-in is-visible mt-3 max-w-xl text-body-md text-body">
      Three disciplines, one team that owns all of it — from first brief to
      production release. Faster than you expect.
    </p>

    <div class="bento-grid mt-10" role="list">
      <!-- Software & Product tile — large 2×2 -->
      <a
        href={`/services#${offerings[0].id}`}
        class="bento-cell bento-span-2 bento-row-2 card-interactive group flex flex-col justify-between p-6 md:p-8"
        role="listitem"
      >
        <div>
          <div
            class="mb-4 flex size-12 items-center justify-center rounded-xl border border-hairline bg-surface-soft text-ink transition-colors group-hover:border-ink group-hover:bg-ink group-hover:text-canvas"
          >
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              {icons.globe.paths.map((d) => <path d={d} />)}
            </svg>
          </div>
          <span class="bento-label">{offerings[0].tagline}</span>
          <h3 class="mt-2 font-display text-heading-lg text-ink md:text-2xl">
            {offerings[0].name}
          </h3>
          <p class="mt-3 max-w-md text-body-sm text-body">
            {offerings[0].description}
          </p>
          <ul class="mt-4 space-y-1.5">
            {
              offerings[0].features.slice(0, 3).map((f) => (
                <li class="flex items-center gap-2 text-body-sm text-charcoal">
                  <span class="text-ink" aria-hidden="true">
                    →
                  </span>
                  {f}
                </li>
              ))
            }
          </ul>
        </div>
        <span
          class="mt-6 text-body-sm font-medium text-ink opacity-0 transition-opacity group-hover:opacity-100"
        >
          See all capabilities →
        </span>
      </a>

      <!-- Consulting tile -->
      <a
        href={`/services#${offerings[1].id}`}
        class="bento-cell card-interactive group flex flex-col gap-3 p-6"
        role="listitem"
      >
        <div
          class="flex size-10 items-center justify-center rounded-lg border border-hairline bg-surface-soft text-ink transition-colors group-hover:border-ink group-hover:bg-ink group-hover:text-canvas"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            {icons.layers.paths.map((d) => <path d={d} />)}
          </svg>
        </div>
        <div>
          <span class="bento-label">{offerings[1].tagline}</span>
          <h3 class="mt-1.5 font-display text-heading-md text-ink">
            {offerings[1].name}
          </h3>
          <p class="mt-2 text-body-sm text-body line-clamp-3">
            {offerings[1].description}
          </p>
        </div>
        <span
          class="mt-auto text-caption-sm font-medium text-ink opacity-0 transition-opacity group-hover:opacity-100"
        >
          Explore →
        </span>
      </a>

      <!-- Partnerships tile -->
      <a
        href={`/services#${offerings[2].id}`}
        class="bento-cell card-interactive group flex flex-col gap-3 p-6"
        role="listitem"
      >
        <div
          class="flex size-10 items-center justify-center rounded-lg border border-hairline bg-surface-soft text-ink transition-colors group-hover:border-ink group-hover:bg-ink group-hover:text-canvas"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            {icons.terminal.paths.map((d) => <path d={d} />)}
          </svg>
        </div>
        <div>
          <span class="bento-label">{offerings[2].tagline}</span>
          <h3 class="mt-1.5 font-display text-heading-md text-ink">
            {offerings[2].name}
          </h3>
          <p class="mt-2 text-body-sm text-body line-clamp-3">
            {offerings[2].description}
          </p>
        </div>
        <span
          class="mt-auto text-caption-sm font-medium text-ink opacity-0 transition-opacity group-hover:opacity-100"
        >
          Explore →
        </span>
      </a>

      <!-- Stats: first two -->
      {
        stats.slice(0, 2).map((s) => (
          <div class="bento-cell bento-stat fade-in p-6" role="listitem">
            <p class="font-display text-3xl font-semibold text-ink md:text-4xl">
              {s.value}
            </p>
            <p class="mt-1 text-body-sm text-body">{s.label}</p>
          </div>
        ))
      }

      <!-- Process highlight — dark tile (no bento-cell: that class sets a translucent white bg which would hide text-on-dark) -->
      <a
        href="/process"
        class="bento-span-2 group relative flex min-h-[140px] flex-col justify-center overflow-hidden rounded-xl bg-surface-dark p-6 text-on-dark transition-transform duration-200 hover:-translate-y-0.5 hover:shadow-lg md:p-8"
        role="listitem"
      >
        <span
          class="text-caption-sm font-medium uppercase tracking-widest text-on-dark-mute"
        >
          How we engage
        </span>
        <p class="mt-2 font-display text-heading-md text-on-dark">
          {processPage.steps.map((s) => s.title).join(" → ")}
        </p>
        <p class="mt-2 text-body-sm text-on-dark-mute">
          Fixed scope · Weekly demos · Clean handoff — every time
        </p>
        <span
          class="mt-4 inline-flex items-center gap-1.5 text-body-sm font-medium text-on-dark opacity-0 transition-opacity group-hover:opacity-100"
        >
          See the full process →
        </span>
      </a>

      <!-- Email CTA tile -->
      <a
        href={`mailto:${siteConfig.contact.email}`}
        class="bento-cell card-interactive group flex flex-col justify-between border border-dashed border-hairline p-6"
        role="listitem"
      >
        <span class="bento-label">Say hello</span>
        <p
          class="font-mono text-body-sm font-medium text-ink group-hover:underline md:text-base"
        >
          {siteConfig.contact.email}
        </p>
        <span class="text-caption-sm text-mute"
          >Reply within 1 business day</span
        >
      </a>

      <!-- Stats: remaining -->
      {
        stats.slice(2).map((s) => (
          <div class="bento-cell bento-stat fade-in p-6" role="listitem">
            <p class="font-display text-2xl font-semibold text-ink">
              {s.value}
            </p>
            <p class="mt-1 text-body-sm text-body">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
