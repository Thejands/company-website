---
import GlobeIcon from "@/components/ui/globe-icon";
import LayersIcon from "@/components/ui/layers-icon";
import TerminalIcon from "@/components/ui/terminal-icon";
import { servicesPage, stats, processPage } from "@/config/content";
import { siteConfig } from "@/config/site";

const offerings = servicesPage.offerings;
---

<section class="section-spacing" aria-labelledby="bento-heading">
  <div class="container-page">
    <h2
      id="bento-heading"
      class="fade-in is-visible font-display text-display-lg text-ink"
    >
      What we build
    </h2>
    <p class="fade-in is-visible mt-3 max-w-xl text-body-md text-body">
      Three disciplines, one team that owns all of it — from first wireframe to
      production release.
    </p>

    <div class="bento-grid mt-10" role="list">
      <!-- Web - large feature tile -->
      <a
        href={`/services#${offerings[0].id}`}
        class="bento-cell bento-span-2 bento-row-2 card-interactive group flex flex-col justify-between p-6 md:p-8"
        role="listitem"
      >
        <div>
          <div
            class="mb-4 flex size-12 items-center justify-center rounded-xl border border-hairline bg-surface-soft text-ink transition-colors group-hover:border-ink"
          >
            <GlobeIcon
              size={22}
              className="text-ink"
              strokeWidth={1.75}
              client:visible
            />
          </div>
          <span class="bento-label">{offerings[0].tagline}</span>
          <h3 class="mt-2 font-display text-heading-lg text-ink md:text-2xl">
            {offerings[0].name}
          </h3>
          <p class="mt-3 max-w-md text-body-sm text-body">
            {offerings[0].description}
          </p>
          <ul class="mt-4 space-y-1.5">
            {
              offerings[0].features.slice(0, 3).map((f) => (
                <li class="flex items-center gap-2 text-body-sm text-charcoal">
                  <span class="text-ink" aria-hidden="true">
                    →
                  </span>
                  {f}
                </li>
              ))
            }
          </ul>
        </div>
        <span
          class="mt-6 text-body-sm font-medium text-ink opacity-0 transition-opacity group-hover:opacity-100"
        >
          See all capabilities →
        </span>
      </a>

      <!-- Mobile tile -->
      <a
        href={`/services#${offerings[1].id}`}
        class="bento-cell card-interactive group flex flex-col gap-3 p-6"
        role="listitem"
      >
        <div
          class="flex size-10 items-center justify-center rounded-lg border border-hairline bg-surface-soft text-ink transition-colors group-hover:border-ink"
        >
          <LayersIcon
            size={20}
            className="text-ink"
            strokeWidth={1.75}
            client:visible
          />
        </div>
        <div>
          <span class="bento-label">{offerings[1].tagline}</span>
          <h3 class="mt-1.5 font-display text-heading-md text-ink">
            {offerings[1].name}
          </h3>
          <p class="mt-2 text-body-sm text-body line-clamp-3">
            {offerings[1].description}
          </p>
        </div>
        <span
          class="mt-auto text-caption-sm font-medium text-ink opacity-0 transition-opacity group-hover:opacity-100"
        >
          Explore →
        </span>
      </a>

      <!-- Custom software tile -->
      <a
        href={`/services#${offerings[2].id}`}
        class="bento-cell card-interactive group flex flex-col gap-3 p-6"
        role="listitem"
      >
        <div
          class="flex size-10 items-center justify-center rounded-lg border border-hairline bg-surface-soft text-ink transition-colors group-hover:border-ink"
        >
          <TerminalIcon
            size={20}
            className="text-ink"
            strokeWidth={1.75}
            client:visible
          />
        </div>
        <div>
          <span class="bento-label">{offerings[2].tagline}</span>
          <h3 class="mt-1.5 font-display text-heading-md text-ink">
            {offerings[2].name}
          </h3>
          <p class="mt-2 text-body-sm text-body line-clamp-3">
            {offerings[2].description}
          </p>
        </div>
        <span
          class="mt-auto text-caption-sm font-medium text-ink opacity-0 transition-opacity group-hover:opacity-100"
        >
          Explore →
        </span>
      </a>

      <!-- Stats bento cells -->
      {
        stats.slice(0, 2).map((s) => (
          <div class="bento-cell bento-stat fade-in p-6" role="listitem">
            <p class="font-display text-3xl font-semibold text-ink md:text-4xl">
              {s.value}
            </p>
            <p class="mt-1 text-body-sm text-body">{s.label}</p>
          </div>
        ))
      }

      <!-- Process highlight - dark tile -->
      <a
        href="/process"
        class="bento-cell bento-span-2 card-interactive group relative flex flex-col justify-center overflow-hidden bg-surface-dark p-6 text-on-dark md:p-8"
        role="listitem"
      >
        <span
          class="flex items-center gap-2 text-caption-sm font-medium text-on-dark-mute"
        >
          How we work
        </span>
        <p class="mt-2 font-display text-heading-md text-on-dark">
          {processPage.steps.map((s) => s.title).join(" → ")}
        </p>
        <p class="mt-2 text-body-sm text-on-dark-mute">
          Fixed scope · Weekly demos · Clean handoff
        </p>
        <span
          class="mt-4 text-body-sm font-medium text-on-dark opacity-0 transition-opacity group-hover:opacity-100"
        >
          See our full process →
        </span>
      </a>

      <!-- Email CTA tile -->
      <a
        href={`mailto:${siteConfig.contact.email}`}
        class="bento-cell card-interactive group flex flex-col justify-between border-dashed p-6"
        role="listitem"
      >
        <span class="bento-label">Say hello</span>
        <p
          class="font-mono text-body-sm font-medium text-ink group-hover:underline md:text-base"
        >
          {siteConfig.contact.email}
        </p>
        <span class="text-caption-sm text-mute"
          >Reply within 1 business day</span
        >
      </a>

      <!-- More stats -->
      {
        stats.slice(2).map((s) => (
          <div class="bento-cell bento-stat fade-in p-6" role="listitem">
            <p class="font-display text-2xl font-semibold text-ink">
              {s.value}
            </p>
            <p class="mt-1 text-body-sm text-body">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
