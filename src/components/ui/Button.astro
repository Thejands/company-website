---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "on-dark";
  type?: "button" | "submit";
  class?: string;
}

const {
  href,
  variant = "primary",
  type = "button",
  class: className = "",
} = Astro.props;

const base =
  "inline-flex h-9 items-center justify-center rounded-full px-5 text-[0.875rem] font-medium leading-none transition-colors";

const variants = {
  primary: "bg-primary text-on-primary hover:bg-ink-deep active:bg-ink-deep",
  secondary:
    "border border-hairline-strong bg-canvas text-ink hover:border-charcoal active:bg-surface-soft",
  "on-dark": "bg-canvas text-ink hover:bg-surface-soft active:bg-surface-soft",
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}
