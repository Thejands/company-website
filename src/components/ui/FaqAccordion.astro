---
interface Item {
  question: string;
  answer: string;
}

interface Props {
  items: readonly Item[];
}

const { items } = Astro.props;
---

<div
  class="divide-y divide-hairline border-y border-hairline"
  data-faq-accordion
>
  {
    items.map((item, i) => (
      <details class="group fade-in" open={i === 0}>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-heading-sm text-ink transition-colors hover:text-charcoal [&::-webkit-details-marker]:hidden">
          <span>{item.question}</span>
          <span
            class="flex size-8 shrink-0 items-center justify-center rounded-full border border-hairline text-body-sm transition-transform group-open:rotate-45"
            aria-hidden="true"
          >
            +
          </span>
        </summary>
        <p class="pb-5 pr-12 text-body-md text-body">{item.answer}</p>
      </details>
    ))
  }
</div>
