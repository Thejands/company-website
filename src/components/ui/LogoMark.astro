---
import { siteConfig } from "@/config/site";

interface Props {
  height?: number;
  class?: string;
}

const { height = 40, class: className = "" } = Astro.props;
const logoWidth = Math.round(height * 2.68);
---

<img
  src={siteConfig.logo}
  alt="Thejands"
  width={logoWidth}
  height={height}
  class:list={["object-contain", className]}
  style={`height: ${height}px; width: auto;`}
  loading="lazy"
  decoding="async"
/>
