---
import PlugConnected from "@/components/icons/PlugConnected";

interface Props {
  size?: number;
  class?: string;
  /** Hydrate on load (header). Default: when visible in viewport. */
  eager?: boolean;
}

const {
  size = 22,
  class: className = "text-ink shrink-0",
  eager = false,
} = Astro.props;
---

{
  eager ? (
    <PlugConnected client:load size={size} className={className} />
  ) : (
    <PlugConnected client:visible size={size} className={className} />
  )
}
