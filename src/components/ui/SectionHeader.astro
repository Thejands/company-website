---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  align = "left",
  class: className = "",
} = Astro.props;
const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
---

<header
  class:list={[
    "max-w-[var(--max-width-prose)] fade-in",
    align === "center" && "max-w-[var(--max-width-content)]",
    alignClass,
    className,
  ]}
>
  {eyebrow && <p class="mb-3 text-body-sm font-medium text-mute">{eyebrow}</p>}
  <h2 class="font-display text-display-lg text-ink">{title}</h2>
  {subtitle && <p class="mt-3 text-body-md text-body">{subtitle}</p>}
</header>
