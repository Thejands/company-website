---
import type { SocialLink } from "@/config/site-env";

interface Props {
  links: SocialLink[];
  class?: string;
}

const { links, class: className = "" } = Astro.props;

const iconPaths: Record<string, string> = {
  instagram:
    "M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5.2a4.8 4.8 0 1 0 0 9.6 4.8 4.8 0 0 0 0-9.6zm6.2-1.3a1.1 1.1 0 1 0 0 2.2 1.1 1.1 0 0 0 0-2.2z",
  facebook:
    "M14 3h4v4h-3.2c-.9 0-1.8.9-1.8 1.8V12H10v4h3v8h4v-8h3.4l.6-4H17V8.8C17 5.6 16.4 3 14 3z",
  linkedin:
    "M6 8h4v12H6V8zm2-6a2.3 2.3 0 1 1 0 4.6A2.3 2.3 0 0 1 8 2zm4 6h4v1.7h.1c.6-1 2-2.1 4.1-2.1 4.4 0 5.2 2.7 5.2 6.2V20h-4v-5.2c0-1.2 0-2.8-1.7-2.8s-2 1.3-2 2.6V20h-4V8z",
  discord:
    "M18.4 5.2A15.6 15.6 0 0 0 14 4l-.4.8a14.4 14.4 0 0 0-3.2 0L10 4a15.6 15.6 0 0 0-4.4 1.2C3.5 8.4 2.6 11.6 3 14.8a15.8 15.8 0 0 0 4.8 2.4l1-1.6a10.4 10.4 0 0 1-1.6-.8l.4-.2a11.6 11.6 0 0 0 10 0l.4.2a10.4 10.4 0 0 1-1.6.8l1 1.6a15.8 15.8 0 0 0 4.8-2.4c.6-4.4-.2-7.6-1.6-9.6zM9.6 13.6c-.8 0-1.4-.8-1.4-1.8s.6-1.8 1.4-1.8 1.4.8 1.4 1.8-.6 1.8-1.4 1.8zm4.8 0c-.8 0-1.4-.8-1.4-1.8s.6-1.8 1.4-1.8 1.4.8 1.4 1.8-.6 1.8-1.4 1.8z",
  x: "M5 4l6.8 9.2L5.2 20h2.4l5.2-6.8L17 20h3l-7.2-9.8L19.4 4H17l-4.8 6.4L9 4H5z",
  github:
    "M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.8c-3 .7-3.6-1.4-3.6-1.4-.5-1.2-1.2-1.5-1.2-1.5-1-.7.1-.7.1-.7 1.1.1 1.7 1.1 1.7 1.1 1 .1.7 1.7 2.5 2.2.9-.2 1.8-.7 2.2-1.3-1.8-.2-3.6-1-3.6-3.7 0-.8.3-1.6.9-2.2-1-.1-2-1.1-2-2.3 0-.6.2-1.2.6-1.6 0 0 1-.3 3.2 1.1a10.6 10.6 0 0 1 5.6 0c2.1-1.4 3.2-1.1 3.2-1.1.4.4.6 1 .6 1.6 0 1.2-1 2.2-2 2.3.6.6.9 1.4.9 2.2 0 2.7-1.8 3.5-3.6 3.7.3.3.6.8.6 1.6v2.4c0 .3.2.6.7.5A10 10 0 0 0 12 2z",
};
---

{
  links.length > 0 && (
    <ul
      class:list={["flex flex-wrap items-center gap-2", className]}
      aria-label="Social media"
    >
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex size-10 items-center justify-center rounded-full border border-hairline text-ink transition-colors hover:bg-surface-soft"
            aria-label={`${link.label} (opens in new tab)`}
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d={iconPaths[link.id] ?? iconPaths.github} />
            </svg>
          </a>
        </li>
      ))}
    </ul>
  )
}
