---
import "@/styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const path = Astro.url.pathname;

const navItems = [
  {
    label: "Inbox",
    href: "/admin/submissions",
    match: "/admin/submissions",
    iconPath:
      "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
  {
    label: "Jobs",
    href: "/admin/jobs",
    match: "/admin/jobs",
    iconPath:
      "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
  },
  {
    label: "Applications",
    href: "/admin/applications",
    match: "/admin/applications",
    iconPath:
      "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
  },
];
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Thejands Admin</title>
    <style>
      :root {
        --color-ink: #0a0a0a;
        --color-mute: #71717a;
        --color-charcoal: #3f3f46;
        --color-body: #52525b;
        --color-canvas: #ffffff;
        --color-surface-soft: #f5f5f4;
        --color-on-primary: #ffffff;
        --color-hairline: #e4e4e7;
        --font-display: "Georgia", "Times New Roman", serif;
      }

      .font-display {
        font-family: var(--font-display);
      }
      .text-ink {
        color: var(--color-ink);
      }
      .text-mute {
        color: var(--color-mute);
      }
      .text-charcoal {
        color: var(--color-charcoal);
      }
      .text-body {
        color: var(--color-body);
      }
      .bg-canvas {
        background-color: var(--color-canvas);
      }
      .bg-surface-soft {
        background-color: var(--color-surface-soft);
      }
      .border-hairline {
        border-color: var(--color-hairline);
      }
      .text-on-primary {
        color: var(--color-on-primary);
      }

      /* Typography scale */
      .text-heading-lg {
        font-size: 1.75rem;
        line-height: 1.2;
        font-weight: 600;
        letter-spacing: -0.02em;
      }
      .text-heading-md {
        font-size: 1.375rem;
        line-height: 1.3;
        font-weight: 600;
        letter-spacing: -0.015em;
      }
      .text-heading-sm {
        font-size: 1.125rem;
        line-height: 1.4;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .text-body-md {
        font-size: 0.9375rem;
        line-height: 1.6;
      }
      .text-body-sm {
        font-size: 0.875rem;
        line-height: 1.5;
      }
      .text-caption-sm {
        font-size: 0.75rem;
        line-height: 1.4;
      }

      /* Sidebar transition */
      #admin-sidebar {
        transition: transform 0.25s ease;
      }
      #sidebar-backdrop {
        transition: opacity 0.25s ease;
      }
    </style>
  </head>
  <body
    class="h-full bg-surface-soft"
    style="font-family: system-ui, -apple-system, sans-serif;"
  >
    <div class="flex h-full">
      <!-- Backdrop (mobile only) -->
      <div
        id="sidebar-backdrop"
        class="fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none md:hidden"
        aria-hidden="true"
      >
      </div>

      <!-- Sidebar -->
      <aside
        id="admin-sidebar"
        class="fixed inset-y-0 left-0 z-50 flex w-[220px] flex-col bg-[#111] md:static md:translate-x-0 md:z-auto -translate-x-full"
        style="min-height: 100vh;"
      >
        <!-- Wordmark -->
        <div
          class="flex flex-col gap-0.5 px-5 pt-6 pb-5 border-b border-white/10"
        >
          <span class="font-display text-white text-xl tracking-tight"
            >Thejands</span
          >
          <span class="text-xs text-white/40" style="font-family: monospace;"
            >admin</span
          >
        </div>

        <!-- Navigation -->
        <nav
          class="flex-1 px-3 py-4 space-y-1"
          role="navigation"
          aria-label="Admin navigation"
        >
          {
            navItems.map((item) => {
              const isActive = path.startsWith(item.match);
              return (
                <a
                  href={item.href}
                  class={`flex items-center gap-3 px-3 py-2.5 text-sm font-medium transition-colors ${
                    isActive
                      ? "bg-white/10 text-white rounded-lg"
                      : "text-white/60 hover:bg-white/8 hover:text-white rounded-lg"
                  }`}
                  aria-current={isActive ? "page" : undefined}
                >
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d={item.iconPath} />
                  </svg>
                  {item.label}
                </a>
              );
            })
          }
        </nav>

        <!-- Sidebar footer -->
        <div class="px-3 py-4 border-t border-white/10 space-y-1">
          <a
            href="/"
            class="flex items-center gap-2 px-3 py-2 text-sm text-white/50 hover:text-white/80 rounded-lg transition-colors"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M19 12H5M12 19l-7-7 7-7"></path>
            </svg>
            Back to site
          </a>
          <button
            id="sidebar-logout-btn"
            class="w-full flex items-center gap-2 px-3 py-2 text-sm text-white/50 hover:text-white/80 rounded-lg transition-colors text-left"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
              ></path>
            </svg>
            Log out
          </button>
        </div>
      </aside>

      <!-- Main area -->
      <div
        class="flex flex-1 flex-col min-w-0 md:ml-0"
        style="min-height: 100vh;"
      >
        <!-- Top bar -->
        <header
          class="sticky top-0 z-30 flex h-14 items-center justify-between border-b border-hairline bg-canvas px-4 md:px-6"
        >
          <!-- Mobile hamburger -->
          <div class="flex items-center gap-3">
            <button
              id="sidebar-toggle"
              class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg text-charcoal hover:bg-surface-soft transition-colors"
              aria-label="Toggle sidebar"
              aria-expanded="false"
              aria-controls="admin-sidebar"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
            <h1 class="font-display text-heading-sm text-ink">{title}</h1>
          </div>

          <!-- Topbar logout -->
          <button
            id="topbar-logout-btn"
            class="text-body-sm text-charcoal hover:text-ink transition-colors hidden md:block"
          >
            Log out
          </button>
        </header>

        <!-- Page content -->
        <main class="flex-1 px-4 md:px-6 py-8">
          <slot />
        </main>
      </div>
    </div>

    <script>
      // Sidebar toggle (mobile)
      const sidebarToggle = document.getElementById("sidebar-toggle");
      const adminSidebar = document.getElementById("admin-sidebar");
      const sidebarBackdrop = document.getElementById("sidebar-backdrop");

      function openSidebar() {
        adminSidebar?.classList.remove("-translate-x-full");
        sidebarBackdrop?.classList.remove("opacity-0", "pointer-events-none");
        sidebarBackdrop?.classList.add("opacity-100");
        sidebarToggle?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
      }

      function closeSidebar() {
        adminSidebar?.classList.add("-translate-x-full");
        sidebarBackdrop?.classList.add("opacity-0", "pointer-events-none");
        sidebarBackdrop?.classList.remove("opacity-100");
        sidebarToggle?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      }

      sidebarToggle?.addEventListener("click", () => {
        const isOpen = !adminSidebar?.classList.contains("-translate-x-full");
        if (isOpen) {
          closeSidebar();
        } else {
          openSidebar();
        }
      });

      sidebarBackdrop?.addEventListener("click", closeSidebar);

      // Logout handler
      async function doLogout() {
        try {
          await fetch("/api/admin/logout", { method: "POST" });
        } catch {
          // ignore
        }
        window.location.href = "/admin";
      }

      document
        .getElementById("sidebar-logout-btn")
        ?.addEventListener("click", doLogout);
      document
        .getElementById("topbar-logout-btn")
        ?.addEventListener("click", doLogout);
    </script>
  </body>
</html>
