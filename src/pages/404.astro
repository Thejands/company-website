---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
---

<BaseLayout
  title="Page not found"
  description="This page does not exist on Thejands."
>
  <section class="section-spacing">
    <div class="container-page text-center">
      <p class="font-mono text-caption-sm text-mute">404</p>
      <h1 class="mt-4 font-display text-display-xl text-ink">
        This page isn't here.
      </h1>
      <p class="mx-auto mt-4 max-w-md text-body-md text-body">
        The link may be outdated - head home or tell us what you were looking
        for.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/">Home</Button>
        <Button href="/contact" variant="secondary">Contact</Button>
      </div>
    </div>
  </section>
</BaseLayout>
