---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";

const quickLinks = [
  {
    num: "01",
    title: "Home",
    desc: "See what we build and who we are",
    href: "/",
  },
  {
    num: "02",
    title: "Services",
    desc: "Software, consulting & partnerships",
    href: "/services",
  },
  {
    num: "03",
    title: "Process",
    desc: "How we engage, from brief to delivery",
    href: "/process",
  },
  {
    num: "04",
    title: "Contact",
    desc: "Start a conversation with the founders",
    href: "/contact",
  },
];
---

<BaseLayout
  title="404 - Page not found"
  description="The page you're looking for doesn't exist on Thejands."
>
  <section class="section-spacing flex min-h-[80vh] items-center">
    <div class="container-page w-full">
      <div class="grid gap-16 lg:grid-cols-[1fr_auto] lg:items-start">
        <!-- Left: error content -->
        <div>
          <!-- Error badge -->
          <div
            class="inline-flex items-center gap-2 rounded-full border border-hairline bg-surface-soft px-3 py-1.5"
          >
            <span class="size-1.5 rounded-full bg-ink/30"></span>
            <span class="font-mono text-caption-sm text-mute"
              >404 · Not found</span
            >
          </div>

          <!-- Ghost number -->
          <div class="relative mt-6 select-none" aria-hidden="true">
            <span
              class="font-display text-[clamp(5rem,18vw,9rem)] font-bold leading-none text-ink/[0.04]"
            >
              404
            </span>
            <div class="absolute inset-0 flex items-center">
              <h1 class="font-display text-display-xl text-ink">
                Page not found.
              </h1>
            </div>
          </div>

          <p class="mt-6 max-w-md text-body-md text-body">
            The link may be outdated or mistyped. Here are some places to go
            instead - or email us and we'll point you in the right direction.
          </p>

          <!-- Primary CTAs -->
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <a
              href="/"
              class="inline-flex h-10 items-center gap-2 rounded-full bg-ink px-6 text-body-sm font-medium text-on-primary transition-opacity hover:opacity-80"
            >
              ← Back home
            </a>
            <a
              href={`mailto:${siteConfig.contact.email}`}
              class="inline-flex h-10 items-center gap-2 rounded-full border border-hairline bg-canvas px-6 text-body-sm font-medium text-ink transition-colors hover:border-ink/40"
            >
              Email us
            </a>
          </div>
        </div>

        <!-- Right: terminal block -->
        <div
          class="hidden overflow-hidden rounded-xl bg-surface-dark lg:block"
          aria-hidden="true"
        >
          <div
            class="flex items-center gap-1.5 border-b border-white/10 px-4 py-3"
          >
            <span class="size-3 rounded-full bg-terminal-red/80"></span>
            <span class="size-3 rounded-full bg-terminal-yellow/80"></span>
            <span class="size-3 rounded-full bg-terminal-green/80"></span>
            <span class="ml-3 font-mono text-caption-sm text-on-dark-mute"
              >thejands-cli</span
            >
          </div>
          <div class="p-5 font-mono text-caption-sm leading-relaxed">
            <p class="text-on-dark-mute">
              $ fetch thejands.in<span id="typed-path" class="text-terminal-red"
              ></span>
            </p>
            <p class="mt-2 text-terminal-red">✗ Error 404: route not matched</p>
            <p class="mt-3 text-on-dark-mute">→ Did you mean one of these?</p>
            <ul class="mt-2 space-y-1 text-on-dark">
              <li><span class="text-terminal-green">→</span> /services</li>
              <li><span class="text-terminal-green">→</span> /process</li>
              <li><span class="text-terminal-green">→</span> /about</li>
              <li><span class="text-terminal-green">→</span> /contact</li>
            </ul>
            <p class="mt-4 text-on-dark-mute">
              $ <span class="animate-pulse">▋</span>
            </p>
          </div>
        </div>
      </div>

      <!-- Quick-navigation grid -->
      <div class="mt-14">
        <p
          class="text-caption-sm font-medium uppercase tracking-widest text-mute"
        >
          Quick navigation
        </p>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {
            quickLinks.map((link) => (
              <a
                href={link.href}
                class="card-interactive group flex flex-col gap-3 p-5"
              >
                <span class="font-mono text-caption-sm text-mute">
                  {link.num}
                </span>
                <div>
                  <p class="font-display text-heading-sm text-ink">
                    {link.title}
                  </p>
                  <p class="mt-1 text-body-sm text-body">{link.desc}</p>
                </div>
                <span class="mt-auto text-body-sm font-medium text-ink opacity-0 transition-opacity group-hover:opacity-100">
                  Go →
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Show the current bad path in the terminal block
  const el = document.getElementById("typed-path");
  if (el) {
    el.textContent = window.location.pathname;
  }
</script>
