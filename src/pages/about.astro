---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/ui/PageHero.astro";
import CtaBand from "@/components/ui/CtaBand.astro";
import Schema from "@/components/seo/Schema.astro";
import { aboutPage } from "@/config/content";
---

<BaseLayout
  title="About Thejands - Enterprise Software & Consulting, India"
  description="Thejands is a founder-led enterprise software and consulting company. Linga and Somu lead every engagement - from architecture to delivery - for mid-market and enterprise organisations worldwide."
  keywords="Thejands founders, enterprise software company India, founder-led software development, Linga Somu Thejands, technology consulting India, enterprise delivery partner"
  breadcrumbs={[
    { name: "Home", item: "https://thejands.in" },
    { name: "About", item: "https://thejands.in/about" },
  ]}
>
  <Fragment slot="head">
    {
      aboutPage.founders.map((founder) => (
        <Schema
          type="Person"
          data={{
            personName: founder.name,
            personRole: founder.role,
            personBio: founder.bio,
            personExpertise: [...founder.strengths],
          }}
        />
      ))
    }
  </Fragment>
  <section class="section-spacing border-b border-hairline">
    <div class="container-page">
      <PageHero
        title={aboutPage.title}
        subtitle={aboutPage.subtitle}
        showBrandIcon
      />
    </div>
  </section>

  <section class="section-spacing">
    <div class="container-page grid gap-16 lg:grid-cols-2">
      <div class="fade-in max-w-[var(--max-width-prose)]">
        <h2 class="font-display text-heading-lg text-ink">
          {aboutPage.story.title}
        </h2>
        {
          aboutPage.story.paragraphs.map((p) => (
            <p class="mt-4 text-body-md text-body">{p}</p>
          ))
        }
      </div>
      <ul class="space-y-4">
        {
          aboutPage.values.map((v) => (
            <li class="card-interactive fade-in p-6">
              <h3 class="font-display text-heading-sm text-ink">{v.title}</h3>
              <p class="mt-2 text-body-sm text-body">{v.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section-spacing bg-surface-soft">
    <div class="container-page">
      <h2 class="fade-in text-center font-display text-display-lg text-ink">
        Meet Linga & Somu
      </h2>
      <p
        class="fade-in mx-auto mt-3 max-w-lg text-center text-body-md text-body"
      >
        Co-founders on every project - strategy, design, and engineering in one
        room.
      </p>
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {
          aboutPage.founders.map((f) => (
            <article class="card-interactive fade-in flex flex-col p-8">
              <div class="mb-6 flex size-14 items-center justify-center rounded-full bg-ink font-display text-xl font-semibold text-on-primary">
                {f.name.charAt(0)}
              </div>
              <h3 class="font-display text-heading-md text-ink">{f.name}</h3>
              <p class="mt-1 text-body-sm font-medium text-mute">{f.role}</p>
              <p class="mt-4 flex-1 text-body-md text-body">{f.bio}</p>
              <ul class="mt-6 space-y-2 border-t border-hairline pt-6">
                {f.strengths.map((s) => (
                  <li class="text-body-sm text-charcoal">✓ {s}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-spacing pb-20">
    <div class="container-page">
      <CtaBand
        title={aboutPage.cta.title}
        body={aboutPage.cta.body}
        button={aboutPage.cta.button}
        dark
      />
    </div>
  </section>
</BaseLayout>
