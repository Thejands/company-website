---
export const prerender = false;

import AdminLayout from "@/layouts/AdminLayout.astro";
import { isAdminRequest } from "@/lib/auth/admin-session";

if (!(await isAdminRequest(Astro.request))) {
  return Astro.redirect("/admin");
}
---

<AdminLayout title="Jobs">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <h1 class="font-display text-heading-lg text-ink">Jobs</h1>
    <button
      type="button"
      id="new-job-btn"
      class="rounded-full bg-ink px-4 py-2 text-body-sm font-medium text-on-primary"
    >
      New job
    </button>
  </div>

  <form
    id="job-form"
    class="mt-8 hidden space-y-4 rounded-lg border border-hairline p-6"
  >
    <h2 class="font-display text-heading-sm text-ink">Create job</h2>
    <input type="hidden" id="job-id" />
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="mb-1 block text-body-sm">Title</label>
        <input
          id="job-title"
          required
          class="h-10 w-full rounded-lg border border-hairline px-3"
        />
      </div>
      <div>
        <label class="mb-1 block text-body-sm">Slug (optional)</label>
        <input
          id="job-slug"
          class="h-10 w-full rounded-lg border border-hairline px-3"
        />
      </div>
      <div>
        <label class="mb-1 block text-body-sm">Department</label>
        <input
          id="job-dept"
          class="h-10 w-full rounded-lg border border-hairline px-3"
        />
      </div>
      <div>
        <label class="mb-1 block text-body-sm">Location</label>
        <input
          id="job-loc"
          class="h-10 w-full rounded-lg border border-hairline px-3"
        />
      </div>
    </div>
    <div>
      <label class="mb-1 block text-body-sm">Status</label>
      <select
        id="job-status"
        class="h-10 rounded-lg border border-hairline px-3"
      >
        <option value="draft">Draft</option>
        <option value="published">Published</option>
        <option value="closed">Closed</option>
      </select>
    </div>
    <div>
      <label class="mb-1 block text-body-sm">Description</label>
      <p class="mb-2 text-caption-sm text-mute">
        Use ## for section headings and - for bullet lists. Blank lines separate
        paragraphs.
      </p>
      <textarea
        id="job-desc"
        required
        rows="16"
        placeholder="## About the role

Short intro paragraph.

## What you will do
- First responsibility
- Second responsibility

## What we are looking for
- Requirement one
- Requirement two"
        class="w-full rounded-lg border border-hairline px-3 py-2 font-mono text-body-sm"
      ></textarea>
    </div>
    <p id="job-form-error" class="hidden text-body-sm text-red-600"></p>
    <div class="flex gap-2">
      <button
        type="submit"
        class="rounded-full bg-ink px-4 py-2 text-body-sm text-on-primary"
        >Save</button
      >
      <button
        type="button"
        id="cancel-job"
        class="rounded-full border border-hairline px-4 py-2 text-body-sm"
        >Cancel</button
      >
    </div>
  </form>

  <div id="jobs-list" class="mt-8 space-y-3"></div>
</AdminLayout>

<script>
  const list = document.getElementById("jobs-list");
  const form = document.getElementById("job-form") as HTMLFormElement;
  const newBtn = document.getElementById("new-job-btn");
  const cancelBtn = document.getElementById("cancel-job");
  const errEl = document.getElementById("job-form-error");

  newBtn?.addEventListener("click", () => {
    form.classList.remove("hidden");
    (document.getElementById("job-id") as HTMLInputElement).value = "";
    form.reset();
  });
  cancelBtn?.addEventListener("click", () => form.classList.add("hidden"));

  async function loadJobs() {
    const res = await fetch("/api/admin/jobs");
    if (res.status === 401) {
      window.location.href = "/admin";
      return;
    }
    const data = (await res.json()) as { jobs?: Array<Record<string, string>> };
    const jobs = data.jobs ?? [];
    if (!list) return;
    list.innerHTML =
      jobs
        .map(
          (j) => `
      <article class="flex flex-wrap items-center justify-between gap-2 rounded-lg border border-hairline p-4">
        <div>
          <p class="font-medium">${j.title}</p>
          <p class="text-caption-sm text-mute">${j.status} · /careers/${j.slug}</p>
        </div>
        <div class="flex gap-2">
          <a href="/admin/applications?job=${j.id}" class="text-body-sm underline">Applications</a>
          <button type="button" data-edit="${j.id}" class="text-body-sm underline">Edit</button>
          <button type="button" data-del="${j.id}" class="text-body-sm text-red-600">Delete</button>
        </div>
      </article>
    `,
        )
        .join("") || "<p class='text-mute'>No jobs yet.</p>";

    list.querySelectorAll("[data-del]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = (btn as HTMLElement).dataset.del;
        if (!id || !confirm("Delete this job?")) return;
        await fetch(`/api/admin/jobs/${id}`, { method: "DELETE" });
        loadJobs();
      });
    });

    list.querySelectorAll("[data-edit]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = (btn as HTMLElement).dataset.edit;
        const job = jobs.find((j) => j.id === id);
        if (!job) return;
        form.classList.remove("hidden");
        (document.getElementById("job-id") as HTMLInputElement).value = job.id;
        (document.getElementById("job-title") as HTMLInputElement).value =
          job.title;
        (document.getElementById("job-slug") as HTMLInputElement).value =
          job.slug;
        (document.getElementById("job-dept") as HTMLInputElement).value =
          job.department ?? "";
        (document.getElementById("job-loc") as HTMLInputElement).value =
          job.location ?? "";
        (document.getElementById("job-status") as HTMLSelectElement).value =
          job.status;
        (document.getElementById("job-desc") as HTMLTextAreaElement).value =
          job.description;
      });
    });
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errEl?.classList.add("hidden");
    const id = (document.getElementById("job-id") as HTMLInputElement).value;
    const payload = {
      title: (document.getElementById("job-title") as HTMLInputElement).value,
      slug: (document.getElementById("job-slug") as HTMLInputElement).value,
      department: (document.getElementById("job-dept") as HTMLInputElement)
        .value,
      location: (document.getElementById("job-loc") as HTMLInputElement).value,
      status: (document.getElementById("job-status") as HTMLSelectElement)
        .value,
      description: (document.getElementById("job-desc") as HTMLTextAreaElement)
        .value,
    };

    const res = id
      ? await fetch(`/api/admin/jobs/${id}`, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        })
      : await fetch("/api/admin/jobs", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

    if (!res.ok) {
      const data = (await res.json()) as { error?: string };
      if (errEl) {
        errEl.textContent = data.error ?? "Save failed";
        errEl.classList.remove("hidden");
      }
      return;
    }
    form.classList.add("hidden");
    loadJobs();
  });

  loadJobs();
</script>
