---
export const prerender = false;

import AdminLayout from "@/layouts/AdminLayout.astro";
import { isAdminRequest } from "@/lib/auth/admin-session";

if (!(await isAdminRequest(Astro.request))) {
  return Astro.redirect("/admin");
}
---

<AdminLayout title="Contact submissions">
  <h1 class="font-display text-heading-lg text-ink">Contact submissions</h1>
  <p class="mt-2 text-body-sm text-body">
    Loaded from Google Sheets. Newest first.
  </p>
  <div id="loading" class="mt-8 text-body-sm text-mute">Loading…</div>
  <div id="submissions" class="mt-8 hidden space-y-4"></div>
  <p id="empty" class="mt-8 hidden text-body-sm text-mute">
    No submissions yet.
  </p>
</AdminLayout>

<script>
  type Row = {
    id: string;
    submittedAt: string;
    name: string;
    email: string;
    message: string;
    pageUrl: string;
    environment: string;
    status: string;
  };

  const loading = document.getElementById("loading");
  const container = document.getElementById("submissions");
  const empty = document.getElementById("empty");

  async function load() {
    const res = await fetch("/api/admin/submissions");
    if (res.status === 401) {
      window.location.href = "/admin";
      return;
    }
    const data = (await res.json()) as { submissions?: Row[] };
    loading?.classList.add("hidden");

    const rows = data.submissions ?? [];
    if (!rows.length) {
      empty?.classList.remove("hidden");
      return;
    }

    container?.classList.remove("hidden");
    if (!container) return;

    container.innerHTML = rows
      .map(
        (r) => `
      <article class="rounded-lg border border-hairline p-4">
        <div class="flex flex-wrap items-start justify-between gap-2">
          <div>
            <p class="font-medium text-ink">${escapeHtml(r.name)}</p>
            <a class="text-body-sm text-ink underline" href="mailto:${escapeHtml(r.email)}">${escapeHtml(r.email)}</a>
          </div>
          <span class="rounded-full border border-hairline px-2 py-0.5 text-caption-sm">${escapeHtml(r.status)}</span>
        </div>
        <p class="mt-2 text-caption-sm text-mute">${escapeHtml(r.submittedAt)} · ${escapeHtml(r.environment)} · ${escapeHtml(r.id.slice(0, 8))}</p>
        <p class="mt-3 whitespace-pre-wrap text-body-sm text-body">${escapeHtml(r.message)}</p>
        ${r.pageUrl ? `<p class="mt-2 text-caption-sm"><a class="underline" href="${escapeHtml(r.pageUrl)}" target="_blank" rel="noopener noreferrer">Source page</a></p>` : ""}
      </article>
    `,
      )
      .join("");
  }

  function escapeHtml(s: string) {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  load();
</script>
