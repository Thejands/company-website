---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ApplyForm from "@/components/careers/ApplyForm.astro";
import Button from "@/components/ui/Button.astro";
import { formatJobDescription } from "@/lib/careers/format-job-description";
import { getSupabasePublic, type Database } from "@/lib/supabase/server";

/** "part_time" → "Part-time", "full_time" → "Full-time", etc. */
function formatEmploymentType(raw: string | null): string {
  if (!raw) return "";
  const map: Record<string, string> = {
    full_time: "Full-time",
    part_time: "Part-time",
    internship: "Internship",
    contract: "Contract",
    "full-time": "Full-time",
    "part-time": "Part-time",
  };
  return map[raw.toLowerCase()] ?? raw.replace(/_/g, "-");
}

/**
 * "Madurai, Tamil Nadu, India" → "Tamil Nadu, India"
 * Strip city prefix when location has 3+ comma-separated parts.
 */
function formatLocation(raw: string | null): string {
  if (!raw) return "";
  const parts = raw.split(", ");
  return parts.length >= 3 ? parts.slice(1).join(", ") : raw;
}

type Job = Database["public"]["Tables"]["jobs"]["Row"];

export const prerender = false;

const { slug } = Astro.params;
const supabase = getSupabasePublic();

if (!supabase || !slug) {
  return Astro.redirect("/careers");
}

const { data: job } = await supabase
  .from("jobs")
  .select("*")
  .eq("slug", slug)
  .eq("status", "published")
  .maybeSingle();

if (!job) {
  return Astro.redirect("/careers");
}

const role: Job = job;
const descriptionHtml = formatJobDescription(role.description);
---

<BaseLayout
  title={role.title}
  description={`Apply for ${role.title} at Thejands.`}
>
  <section class="border-b border-hairline py-10">
    <div class="container-page max-w-5xl">
      <p class="text-body-sm text-mute">
        <a href="/careers" class="underline underline-offset-2">Careers</a>
      </p>
      <h1 class="mt-3 font-display text-display-lg text-ink">{role.title}</h1>
      <p class="mt-2 text-body-sm text-mute">
        {
          [
            role.department,
            formatLocation(role.location),
            formatEmploymentType(role.employment_type),
          ]
            .filter(Boolean)
            .join(" · ")
        }
      </p>
    </div>
  </section>

  <section class="py-12 lg:py-16">
    <div
      class="container-page max-w-5xl grid gap-12 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] lg:items-start"
    >
      <article class="job-description max-w-none">
        <div set:html={descriptionHtml} />
      </article>
      <div class="card-interactive p-8 lg:sticky lg:top-24 self-start">
        <h2 class="font-display text-heading-md text-ink">Apply</h2>
        <div class="mt-6">
          <ApplyForm jobSlug={role.slug} jobTitle={role.title} />
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing border-t border-hairline pb-20">
    <div class="container-page">
      <Button href="/careers" variant="secondary">All open roles</Button>
    </div>
  </section>
</BaseLayout>
