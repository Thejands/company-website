---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/ui/PageHero.astro";
import Button from "@/components/ui/Button.astro";
import { getSupabasePublic, type Database } from "@/lib/supabase/server";

function formatEmploymentType(raw: string | null): string {
  if (!raw) return "";
  const map: Record<string, string> = {
    full_time: "Full-time",
    part_time: "Part-time",
    internship: "Internship",
    contract: "Contract",
    "full-time": "Full-time",
    "part-time": "Part-time",
  };
  return map[raw.toLowerCase()] ?? raw.replace(/_/g, "-");
}

function formatLocation(raw: string | null): string {
  if (!raw) return "";
  const parts = raw.split(", ");
  return parts.length >= 3 ? parts.slice(1).join(", ") : raw;
}

type PublishedJob = Pick<
  Database["public"]["Tables"]["jobs"]["Row"],
  | "slug"
  | "title"
  | "department"
  | "location"
  | "employment_type"
  | "published_at"
>;

let openRoles: PublishedJob[] = [];
const supabase = getSupabasePublic();

if (supabase) {
  const { data } = await supabase
    .from("jobs")
    .select("slug, title, department, location, employment_type, published_at")
    .eq("status", "published")
    .order("published_at", { ascending: false });
  openRoles = data ?? [];
}
---

<BaseLayout
  title="Careers at Thejands — Enterprise Software & Consulting Roles"
  description="Join Thejands and work on enterprise-grade software, consulting programmes, and digital platforms — directly alongside the founders on every engagement. Senior roles only."
  keywords="careers at Thejands, enterprise software developer jobs India, technology consulting roles, senior software engineer hiring, Moodle developer job, full-stack engineer consulting firm India, enterprise developer careers"
  breadcrumbs={[
    { name: "Home", item: "https://thejands.in" },
    { name: "Careers", item: "https://thejands.in/careers" },
  ]}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebPage",
        "@id": "https://thejands.in/careers#webpage",
        url: "https://thejands.in/careers",
        name: "Careers at Thejands — Enterprise Software & Consulting Roles",
        description:
          "Join Thejands and work on enterprise-grade software, consulting programmes, and digital platforms — directly alongside the founders on every engagement. Senior roles only.",
        isPartOf: { "@id": "https://thejands.in/#website" },
        publisher: { "@id": "https://thejands.in/#organization" },
        breadcrumb: {
          "@type": "BreadcrumbList",
          itemListElement: [
            {
              "@type": "ListItem",
              position: 1,
              name: "Home",
              item: "https://thejands.in",
            },
            {
              "@type": "ListItem",
              position: 2,
              name: "Careers",
              item: "https://thejands.in/careers",
            },
          ],
        },
      })}
    />
  </Fragment>
  <section class="border-b border-hairline py-12">
    <div class="container-page">
      <PageHero
        title="Work with us"
        subtitle="We build enterprise-grade software, consult on complex technology programmes, and partner with organisations that expect precision. When we hire, we look for people who care as much about the outcome as the craft."
        showBrandIcon
      />
    </div>
  </section>

  <section class="py-12 pb-20">
    <div class="container-page max-w-5xl">
      {
        openRoles.length === 0 ? (
          <div class="card-interactive p-8 text-center">
            <p class="text-body-md text-body">
              No open roles listed right now. If you have strong experience in
              enterprise software, platform consulting, or technical delivery —
              send your CV and a note about what you're looking for to{" "}
              <a href="mailto:hello@thejands.in" class="text-ink underline">
                hello@thejands.in
              </a>
              . We keep strong profiles on file.
            </p>
            <div class="mt-6">
              <Button href="/contact">Start a conversation</Button>
            </div>
          </div>
        ) : (
          <ul class="space-y-4">
            {openRoles.map((job) => (
              <li>
                <a
                  href={`/careers/${job.slug}`}
                  class="card-interactive block p-6 transition-colors hover:border-ink/30"
                >
                  <h2 class="font-display text-heading-md text-ink">
                    {job.title}
                  </h2>
                  <p class="mt-1 text-body-sm text-mute">
                    {[
                      job.department,
                      formatLocation(job.location),
                      formatEmploymentType(job.employment_type),
                    ]
                      .filter(Boolean)
                      .join(" · ")}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>
