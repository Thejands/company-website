---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/ui/PageHero.astro";
import ContactForm from "@/components/ui/ContactForm.astro";
import FaqAccordion from "@/components/ui/FaqAccordion.astro";
import { contactPage, faq, testimonials } from "@/config/content";
import { siteConfig } from "@/config/site";
---

<BaseLayout
  title="Contact Thejands - Start a Project or Consulting Enquiry"
  description="Share your brief with Thejands. We respond within one business day with an honest read on fit, a rough timeline, and whether we're the right partner - from Linga or Somu directly."
  keywords="hire enterprise software developer India, Moodle consulting enquiry, technology consulting contact, start software project India, enterprise development partner enquiry"
  breadcrumbs={[
    { name: "Home", item: "https://thejands.in" },
    { name: "Contact", item: "https://thejands.in/contact" },
  ]}
  faqs={faq.items.map((item) => ({
    question: item.question,
    answer: item.answer,
  }))}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ContactPage",
        "@id": `${siteConfig.url}/contact#webpage`,
        url: `${siteConfig.url}/contact`,
        name: "Contact Thejands - Start a Project or Consulting Enquiry",
        description:
          "Share your brief with Thejands. We respond within one business day with an honest read on fit, a rough timeline, and whether we're the right partner - from Linga or Somu directly.",
        isPartOf: { "@id": `${siteConfig.url}/#website` },
        publisher: { "@id": `${siteConfig.url}/#organization` },
        mainEntity: {
          "@type": "Organization",
          "@id": `${siteConfig.url}/#organization`,
        },
      })}
    />
  </Fragment>

  <section class="section-spacing border-b border-hairline">
    <div class="container-page">
      <PageHero
        title={contactPage.title}
        subtitle={contactPage.subtitle}
        showBrandIcon
      />
      <p class="fade-in mt-2 max-w-lg text-body-sm text-mute">
        {contactPage.formNote}
      </p>
    </div>
  </section>

  <section class="section-spacing">
    <div class="container-page grid gap-16 lg:grid-cols-[1fr_1.1fr]">
      <div class="fade-in space-y-8">
        <div>
          <h2 class="font-display text-heading-md text-ink">Direct line</h2>
          <ul class="mt-4 space-y-3 text-body-md">
            <li>
              <a
                href={`mailto:${siteConfig.contact.email}`}
                class="text-ink underline underline-offset-4"
              >
                {siteConfig.contact.email}
              </a>
            </li>
            {
              siteConfig.contact.phones.map((phone) => (
                <li>
                  <a
                    href={`tel:${phone.replace(/\s/g, "")}`}
                    class="text-ink underline underline-offset-4"
                  >
                    {phone}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <blockquote class="card-interactive p-6">
          <p class="text-body-md text-body">"{testimonials[0].quote}"</p>
          <footer class="mt-3 text-body-sm text-mute">
            - {testimonials[0].name}, {testimonials[0].role}
          </footer>
        </blockquote>
      </div>

      <div class="fade-in card-interactive p-8 md:p-10">
        <ContactForm />
      </div>
    </div>
  </section>

  <section class="section-spacing border-t border-hairline pb-20">
    <div class="container-page max-w-3xl">
      <h2 class="fade-in font-display text-display-lg text-ink">{faq.title}</h2>
      <div class="mt-8">
        <FaqAccordion items={faq.items} />
      </div>
    </div>
  </section>
</BaseLayout>
