---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Cookie Policy"
  description="How Thejands uses cookies and similar technologies."
>
  <article
    class="section-spacing mx-auto max-w-[var(--max-width-content)] px-6"
  >
    <h1 class="font-display text-display-lg text-ink">Cookie Policy</h1>
    <p class="mt-4 text-body-md text-body">
      We use essential cookies only where required for site functionality.
      Analytics (e.g. Vercel Analytics) may collect anonymized usage data to
      improve performance. You can disable non-essential cookies in your browser
      settings.
    </p>
    <p class="mt-4 text-body-md text-body">
      See our <a href="/privacy" class="text-ink underline">Privacy Policy</a> for
      how we handle personal data.
    </p>
  </article>
</BaseLayout>
