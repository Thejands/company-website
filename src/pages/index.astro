---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
import PlugIcon from "@/components/ui/PlugIcon.astro";
import SnippetPill from "@/components/ui/SnippetPill.astro";
import CtaBand from "@/components/ui/CtaBand.astro";
import HomeBento from "@/components/sections/HomeBento.astro";
import StickyShowcase from "@/components/sections/StickyShowcase.astro";
import { home, testimonials, techStack } from "@/config/content";
import { siteConfig } from "@/config/site";
---

<BaseLayout
  title={siteConfig.title}
  description={siteConfig.description}
  ignoreTitleTemplate={true}
>
  <!-- Hero -->
  <section class="section-spacing border-b border-hairline/60">
    <div class="container-page">
      <p
        class="fade-in is-visible mb-4 inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas/80 px-4 py-1.5 text-caption-sm font-medium text-charcoal backdrop-blur-sm"
      >
        <PlugIcon size={18} class="text-charcoal" />
        {home.eyebrow}
      </p>
      <h1
        class="fade-in is-visible font-display text-display-xl max-w-3xl text-ink"
      >
        {home.headline}
      </h1>
      <p
        class="fade-in is-visible mt-5 max-w-[var(--max-width-prose)] text-body-md text-body"
      >
        {home.subhead}
      </p>
      <div class="fade-in is-visible mt-6 max-w-md">
        <SnippetPill
          href={`mailto:${siteConfig.contact.email}`}
          label={siteConfig.contact.email}
        />
      </div>
      <div class="fade-in is-visible mt-8 flex flex-wrap items-center gap-3">
        <Button href={home.primaryCta.href}>{home.primaryCta.label}</Button>
        <Button href={home.secondaryCta.href} variant="secondary">
          {home.secondaryCta.label}
        </Button>
      </div>
      <ul
        class="fade-in is-visible mt-10 flex flex-wrap gap-x-8 gap-y-2 border-t border-hairline/80 pt-8"
      >
        {
          home.proof.map((item) => (
            <li class="flex items-center gap-2 text-body-sm text-charcoal">
              <span class="text-ink" aria-hidden="true">
                ✓
              </span>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <HomeBento />

  <StickyShowcase />

  <!-- Testimonials -->
  <section class="section-spacing">
    <div class="container-page">
      <h2 class="fade-in font-display text-display-lg text-ink">
        What clients say
      </h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          testimonials.map((t) => (
            <blockquote class="card-interactive fade-in flex flex-col p-6 backdrop-blur-sm">
              <p class="flex-1 text-body-md text-ink">"{t.quote}"</p>
              <footer class="mt-4 text-body-sm">
                <span class="font-medium text-ink">{t.name}</span>
                <span class="text-mute"> · {t.role}</span>
              </footer>
            </blockquote>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Tech -->
  <section class="section-spacing border-t border-hairline/60">
    <div class="container-page text-center">
      <h2 class="fade-in mx-auto font-display text-display-lg text-ink">
        {techStack.title}
      </h2>
      <p class="fade-in mx-auto mt-3 max-w-lg text-body-md text-body">
        {techStack.subtitle}
      </p>
      <div
        class="fade-in mx-auto mt-10 flex max-w-3xl flex-wrap justify-center gap-2"
      >
        {
          techStack.items.map((name) => (
            <span class="rounded-full border border-hairline bg-canvas/80 px-4 py-2 text-body-sm text-charcoal backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:border-ink hover:text-ink hover:shadow-sm">
              {name}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-spacing pb-24">
    <div class="container-page">
      <CtaBand
        title="Ready to build?"
        body={`Share your idea at ${siteConfig.contact.email} - we'll respond with honest next steps.`}
        button={{ label: "Start your project", href: "/contact" }}
        dark
      />
    </div>
  </section>
</BaseLayout>
